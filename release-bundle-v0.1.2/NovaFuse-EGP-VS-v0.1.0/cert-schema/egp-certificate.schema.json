{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novafuse.example/schema/egp-certificate.schema.json",
  "title": "NovaFuse EGP Certificate",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "schema_version",
    "certificate_id",
    "issued_at",
    "profile",
    "component",
    "harness",
    "results",
    "integrity",
    "artifacts"
  ],

  "properties": {
    "schema_version": {
      "type": "string",
      "const": "egp-certificate-0.1"
    },

    "certificate_id": {
      "type": "string",
      "description": "Unique certificate identifier (UUID or deterministic ID)."
    },

    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "Certificate issuance timestamp (informational; MUST NOT affect determinism hashes)."
    },

    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "profile_version"],
      "properties": {
        "profile_id": { "type": "string", "const": "NovaFuse-EGP" },
        "profile_version": { "type": "string", "const": "0.1" },
        "scope_note": {
          "type": "string",
          "description": "Optional textual statement of what is in/out of scope."
        }
      }
    },

    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "description": "Component under test (e.g., novadust)." },
        "version": { "type": "string", "description": "Component version (e.g., 0.1.0)." },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "commit": { "type": "string" },
            "build_id": { "type": "string" }
          }
        }
      }
    },

    "harness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "entrypoint"],
      "properties": {
        "name": { "type": "string", "const": "NovaFuse-EGP-VS" },
        "version": { "type": "string", "description": "Harness version (e.g., 0.1.0)." },
        "entrypoint": { "type": "string", "description": "Verifier entrypoint (e.g., verifier/verify.ps1)." }
      }
    },

    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall", "claims", "tests_run"],
      "properties": {
        "overall": { "type": "string", "enum": ["PASS", "FAIL"] },

        "claims": {
          "type": "object",
          "additionalProperties": false,
          "required": ["EG01", "EG02", "EG03", "EG04", "EG05", "EG06"],
          "properties": {
            "EG01": { "$ref": "#/$defs/claimResult" },
            "EG02": { "$ref": "#/$defs/claimResult" },
            "EG03": { "$ref": "#/$defs/claimResult" },
            "EG04": { "$ref": "#/$defs/claimResult" },
            "EG05": { "$ref": "#/$defs/claimResult" },
            "EG06": { "$ref": "#/$defs/claimResult" }
          }
        },

        "tests_run": {
          "type": "array",
          "description": "List of executed test vector IDs or suite IDs.",
          "items": { "type": "string" },
          "minItems": 1
        },

        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "total_duration_ms": { "type": "integer", "minimum": 0 },
            "suite_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },

    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifier_sha256",
        "profile_sha256",
        "tests_sha256"
      ],
      "properties": {
        "verifier_sha256": { "$ref": "#/$defs/sha256" },
        "profile_sha256": { "$ref": "#/$defs/sha256" },
        "tests_sha256": {
          "type": "object",
          "description": "Hashes for test suites or a single manifest hash.",
          "additionalProperties": false,
          "oneOf": [
            {
              "required": ["manifest_sha256"],
              "properties": {
                "manifest_sha256": { "$ref": "#/$defs/sha256" }
              }
            },
            {
              "required": ["suite_hashes"],
              "properties": {
                "suite_hashes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["suite", "sha256"],
                    "properties": {
                      "suite": { "type": "string" },
                      "sha256": { "$ref": "#/$defs/sha256" }
                    }
                  },
                  "minItems": 1
                }
              }
            }
          ]
        },

        "sbom_spdx_sha256": {
          "$ref": "#/$defs/sha256",
          "description": "Optional: hash of the SBOM artifact if included."
        }
      }
    },

    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["certificate_path"],
      "properties": {
        "certificate_path": { "type": "string" },
        "logs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sbom_spdx_path": { "type": "string" }
      }
    },

    "signature": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional signature block. If required, move it to 'required'.",
      "required": ["alg", "key_id", "value"],
      "properties": {
        "alg": { "type": "string", "description": "Signature algorithm identifier." },
        "key_id": { "type": "string", "description": "Identifier for the signing key." },
        "value": { "type": "string", "description": "Signature value (e.g., base64)." }
      }
    },

    "notes": {
      "type": "string",
      "description": "Optional assessor/developer notes (non-normative)."
    }
  },

  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "claimResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "FAIL"] },
        "details": { "type": "string", "description": "Non-normative human-readable detail." },
        "vectors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Test vectors relevant to this claim."
        }
      }
    }
  }
}
