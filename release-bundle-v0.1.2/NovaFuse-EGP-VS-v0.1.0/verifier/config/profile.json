{
  "profile": {
    "name": "NovaFuse-EGP-0.1",
    "version": "0.1.0",
    "componentName": "reference-component",
    "egpVersion": "0.1",
    "description": "NovaFuse Evidence Governance Protocol verification profile",
    "timestamp": "2026-03-09T04:21:00Z"
  },
  "verification": {
    "determinismRuns": 10,
    "timeoutSeconds": 300,
    "parallelExecution": false,
    "strictMode": true
  },
  "testMatrix": {
    "EG01_Determinism": {
      "enabled": true,
      "runs": 100,
      "randomizedOrder": true,
      "expectedHashUniqueness": 2
    },
    "EG02_Refusal": {
      "enabled": true,
      "invalidProposals": [
        "missing_required_fields",
        "disallowed_actions",
        "malformed_syntax",
        "overflow_conditions"
      ],
      "expectExplicitRefusal": true
    },
    "EG03_AuthoritySeparation": {
      "enabled": true,
      "staticAnalysis": true,
      "runtimeInspection": true,
      "forbiddenCapabilities": [
        "proposal_generation",
        "self_modification",
        "privilege_escalation"
      ]
    },
    "EG04_IdentityBinding": {
      "enabled": true,
      "testIdentities": [
        "admin",
        "user",
        "service",
        "anonymous"
      ],
      "requireIdentity": true,
      "failOnMissing": true
    },
    "EG05_Evidence": {
      "enabled": true,
      "logRequirements": [
        "proposal",
        "context",
        "identity",
        "outcome",
        "constraints",
        "version"
      ],
      "cryptographicSigning": true,
      "replayVerification": true
    },
    "EG06_FailClosed": {
      "enabled": true,
      "failureConditions": [
        "missing_context",
        "corrupt_identity",
        "internal_error",
        "resource_exhaustion"
      ],
      "expectRefusal": true,
      "noPartialExecution": true
    }
  },
  "artifacts": {
    "logFormat": "json",
    "compression": true,
    "retentionDays": 90,
    "signatureAlgorithm": "SHA256"
  },
  "compliance": {
    "standards": ["ISO-27001", "NIST-800-53", "SOC2"],
    "exportControl": true,
    "auditTrail": true
  }
}
